# =========================================================================
# Andrés Core — variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitees `.env` al repo. `.env` está en `.gitignore`.
# =========================================================================

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR
OPENAI_API_KEY=sk-REEMPLAZAR

# Modelos por defecto (ver PROYECTO.md §6)
ANTHROPIC_MODEL_MAIN=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
OPENAI_MODEL_AUX=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Supabase (Fase 1+) ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# --- Cifrado app-level (Fase 1+) ---
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Redis / cola RQ (Fase 2+) ---
REDIS_URL=redis://localhost:6379/0

# --- FastAPI ---
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development

# --- Telegram (alertas Cachito) (Fase 5+) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp Business / n8n (Fase 5+) ---
WABA_TOKEN=
WABA_PHONE_ID=
N8N_WEBHOOK_URL=

# --- Plaud / Zapier (Fase 2) ---
PLAUD_WEBHOOK_SECRET=
ZAPIER_WEBHOOK_TOKEN=

# --- Gmail / Google (vía MCP o OAuth) (Fase 1+) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Notion (Fase 1+) ---
NOTION_API_TOKEN=

# --- Twilio + Vapi (Fase 7+) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
VAPI_API_KEY=

# --- ElevenLabs (Fase 7+) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_GENERIC=
ELEVENLABS_VOICE_ID_CLONED=

# --- Browser automation (Fase 6+) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Observabilidad (Fase 4+) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LOG_LEVEL=INFO
LOG_FORMAT=json
